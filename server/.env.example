# .env.example
# WARNING: PLEASE USE THIS FILE AS A TEMPLATE AND RENAME IT TO ".env" BEFORE RUNNING THE SERVER.

# Vercel deployment notes:
# - Keep this server in its own Vercel project.
# - Set FRONTEND_URL to your deployed client URL.
# - Set GOOGLE_REDIRECT_URI to your deployed server callback URL, or let Vercel derive it from VERCEL_URL.
# - Vercel provides PORT automatically; PORT is only needed for local development.

PORT=3000
FRONTEND_URL=http://localhost:5173

# Google OAuth web client credentials.
# The redirect URI must match exactly what you add in Google Cloud Console.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

# Optional cookie settings.
AUTH_SESSION_COOKIE_NAME=workspace_session
AUTH_STATE_COOKIE_NAME=workspace_oauth_state
AUTH_SESSION_DURATION_DAYS=30
AUTH_COOKIE_SECURE=false

# Brevo transactional email API.
# BREVO_FROM_EMAIL must be a sender verified inside Brevo.
BREVO_API_KEY=
BREVO_FROM_EMAIL=

MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your-password
MYSQL_DATABASE=your_database

# Use this for Aiven or any MySQL server that requires TLS.
# Set to "required" to enable SSL.
# MYSQL_SSL_MODE=disabled

# Optional: paste the CA certificate contents here, or point to a file path.
# MYSQL_SSL_CA=
# MYSQL_SSL_CA_PATH=./certs/aiven-ca.pem

# Optional: set to false if you are intentionally connecting to a server
# with a self-signed certificate in a local test environment.
# MYSQL_SSL_REJECT_UNAUTHORIZED=true
