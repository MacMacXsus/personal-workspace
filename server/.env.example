# .env.example
# WARNING: PLEASE USE THIS FILE AS A TEMPLATE AND RENAME IT TO ".env" BEFORE RUNNING THE SERVER.

PORT=3000

MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your-password
MYSQL_DATABASE=your_database

# Use this for Aiven or any MySQL server that requires TLS.
# Set to "required" to enable SSL.
MYSQL_SSL_MODE=disabled

# Optional: paste the CA certificate contents here, or point to a file path.
# MYSQL_SSL_CA=
# MYSQL_SSL_CA_PATH=./certs/aiven-ca.pem

# Optional: set to false if you are intentionally connecting to a server
# with a self-signed certificate in a local test environment.
# MYSQL_SSL_REJECT_UNAUTHORIZED=true
